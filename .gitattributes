**/__snapshots__/** linguist-generated=true

# Force LF line endings for all text files (critical for Docker/Linux builds)
* text=auto eol=lf
*.sh text eol=lf
*.bash text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.conf text eol=lf
*.options text eol=lf
Dockerfile* text eol=lf
.dockerignore text eol=lf
